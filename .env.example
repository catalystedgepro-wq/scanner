# Catalyst Edge — example environment file. Copy to .env and fill in.
# .env is gitignored. NEVER commit a populated .env.

# ── Required ───────────────────────────────────────────────────────────
SEC_USER_AGENT=YourApp/1.0 your-email@example.com

# ── Optional: tier-1 news ──────────────────────────────────────────────
# Free tier 25 req/day at https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=

# ── Optional: cross-domain sources ─────────────────────────────────────
# Free signup at https://firms.modaps.eosdis.nasa.gov
NASA_FIRMS_MAP_KEY=

# Free signup at https://dash.cloudflare.com → API tokens
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ── Optional: AI scoop drafter ─────────────────────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=

# ── Optional: live trading (require careful review of LICENSE) ─────────
TRADIER_API_TOKEN=
TRADIER_ACCOUNT_ID=
TRADIER_LIVE=0
TRADIER_AGENT_ENABLED=0

COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_LIVE_ORDERS=0
