      "parameters": {
        "jsCode": "const raw = $json.stdout || '{}';\nconst parsed = JSON.parse(raw);\nreturn [{\n  valid: Boolean(parsed.valid),\n  everos_enabled: parsed.everos_enabled || 'unset',\n  runtime_guard_ok: Boolean(parsed.runtime_guard_ok),\n  missing: parsed.missing || [],\n  raw: parsed,\n}];"
